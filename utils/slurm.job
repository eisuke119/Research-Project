#!/bin/bash

#SBATCH --job-name=gpu_job
#SBATCH --output=job.%j.out
#SBATCH --partition=brown  
#SBATCH --nodelist=cn6     # Specify node with 6x Tesla V100 GPUs
#SBATCH --gres=gpu:6       # Request all 6 GPUs on this node
#SBATCH --cpus-per-task=16 # Allocate a reasonable number of CPU cores
#SBATCH --time=02:00:00    # Set the job duration

python main_test.py